# --- Notion ---
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_TASKS_DB_ID=
NOTION_CATEGORIES_DB_ID=
NOTION_USERS_DB_ID=
NOTION_LOGS_DB_ID=

# --- LINE Messaging API ---
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# --- Auth ---
JWT_SECRET=change-me-in-production

# --- Internal service-to-service auth (Scheduler + AI module -> Backend) ---
