# --- AI module base URL (for orchestration calls, if backend triggers it) ---
AI_MODULE_URL=http://localhost:8000

# --- Google Calendar sync (optional — leave blank to disable) ---
# See scripts/google-oauth-setup.ts for how to mint GOOGLE_REFRESH_TOKEN.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary

PORT=4000
